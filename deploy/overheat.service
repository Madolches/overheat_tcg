[Unit]
Description=Overheat API and Socket.IO server
After=network.target mariadb.service

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/overheat_test
Environment=NODE_ENV=production
Environment=PORT=3001
Environment=DB_CONNECTION_LIMIT=4
Environment=NODE_OPTIONS=--max-old-space-size=1024
Environment=TRIGGER_VISUAL_DELAY_MS=1500
Environment=STACK_VISUAL_DELAY_MS=1500
Environment=STACK_BETWEEN_ITEMS_DELAY_MS=1500
Environment=PATH=/home/ubuntu/.nvm/versions/node/v25.8.1/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/ubuntu/.nvm/versions/node/v25.8.1/bin/npm run start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
