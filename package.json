{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "init": "tsx server/init_db.ts && tsx server/init_store.ts && tsx server/seed_admin.ts",
    "deletecards": "tsx server/delete_user_cards.ts",
    "resetcards": "tsx server/reset_all_user_cards.ts",
    "refillcards": "tsx server/refill_user_cards.ts",
    "generate:card-scripts": "tsx script/generate-card-scripts.ts",
    "scripts:audit-progress": "tsx script/audit-card-script-progress.ts",
    "scripts:test-sp02": "tsx script/test-sp02-scenarios.ts",
    "scripts:test-bt06": "tsx script/test-bt06-scenarios.ts",
    "scripts:test-bt07": "tsx script/test-bt07-scenarios.ts",
    "ai:evaluate": "tsx script/evaluate-ai.ts",
    "ai:audit-effects": "tsx script/audit-hard-ai-effects.ts",
    "ai:behavior-audit": "tsx script/report-ai-behavior-audit.ts",
    "ai:learn-effect-timing": "tsx script/learn-effect-timing.ts",
    "ai:test-scenarios": "tsx script/test-hard-ai-scenarios.ts",
    "ai:report-live": "tsx script/report-live-ai.ts",
    "dev": "concurrently \"npm run frontend\" \"npm run backend:dev\"",
    "close": "bash script/close-dev.sh",
    "frontend": "vite --port=3000 --host=0.0.0.0",
    "backend:dev": "tsx watch server/index.ts",
    "backend": "node --max-old-space-size=1024 build/server/index.js",
    "backend:tsx": "node --max-old-space-size=1024 --import tsx server/index.ts",
    "start": "npm run backend",
    "build": "vite build && npm run compress:dist && npm run build:server",
    "build:client": "vite build",
    "build:server": "node script/build-server.mjs",
    "compress:dist": "tsx script/compress-dist.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mariadb": "^3.5.2",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  }
}
